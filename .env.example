# TestPilot AI — Environment Variable Template
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/testpilot

# ─── AI Providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CrewAI (for Python agent backend) ───────────────────────────────────────
CREWAI_API_KEY=your_crewai_api_key_here

# ─── Web Search ──────────────────────────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_string

# ─── Python Agent Backend (optional) ─────────────────────────────────────────
# Leave defaults unless running on a different host/port
AUTOGLM_BASE_URL=http://localhost:8000/v1
AUTOGLM_MODEL=autoglm-phone-9b
AGENT_API_PORT=8080
AGENT_API_URL=http://localhost:8080
